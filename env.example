# Local environment overrides for rhoai3-coding-demo
# Copy to .env and fill in values as needed.
# All deploy/validate scripts call load_env() which sources .env if present.

# --- Required for external model inference (Stage 050) ---
# OpenAI API key for governed external models (gpt-4o, gpt-4o-mini).
# deploy.sh provisions this into the openai-api-key Secret in the maas namespace.
# Without this, external models register but inference calls fail.
OPENAI_API_KEY=

# --- Optional: MCP server credentials (Stage 060) ---
# These enable optional MCP components. Leave empty to skip.

# Slack MCP server — enables AI assistants to post to Slack channels.
# Requires a Slack App with chat:write scope. Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=

# BrightData MCP server — enables AI assistants to browse/search the public web.
# Get from: https://brightdata.com/cp/setting/users
BRIGHTDATA_API_TOKEN=

# --- Optional: GPU demo resume controls ---
# Used by scripts/resume-gpu-demo.sh when resuming Stage 020/030 after GPU
# nodes were scaled to zero for cost saving.
GPU_MACHINESET_REPLICAS=2
GPU_RESUME_TIMEOUT_SECONDS=1800

# --- Optional: Stage 040 GuideLLM load test controls ---
# Stage 040 validation runs a short GuideLLM load test when a MaaS API key is
# available. Defaults are intentionally small for demo environments.
GUIDELLM_SKIP_LOAD_TEST=false
GUIDELLM_MODEL=nemotron-3-nano-30b-a3b
GUIDELLM_PROFILE=constant
GUIDELLM_RATE=1
GUIDELLM_MAX_SECONDS=20
GUIDELLM_REQUESTS=5
GUIDELLM_PROCESSOR=gpt2
GUIDELLM_OUTPUT_TOKENS=64
GUIDELLM_PROMPT="Explain why governed model access matters for enterprise software teams. Keep the answer concise."
GUIDELLM_COMPARE_MODELS="gpt-oss-20b nemotron-3-nano-30b-a3b"

# --- Optional: Stage 050 external model smoke test controls ---
# External inference validation is opt-in because it can spend provider tokens.
GUIDELLM_EXTERNAL_SMOKE_TEST=false
