# Local environment overrides for rhoai3-coding-demo
# Copy to .env and fill in values as needed.
# All deploy/validate scripts call load_env() which sources .env if present.

# --- Required for external model inference (Step 03) ---
# OpenAI API key for governed external models (gpt-4o, gpt-4o-mini).
# deploy.sh provisions this into the openai-api-key Secret in the maas namespace.
# Without this, external models register but inference calls fail.
OPENAI_API_KEY=

# --- Optional: MCP server credentials (Step 03) ---
# These enable optional MCP components. Leave empty to skip.

# Slack MCP server — enables AI assistants to post to Slack channels.
# Requires a Slack App with chat:write scope. Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=

# BrightData MCP server — enables AI assistants to browse/search the public web.
# Get from: https://brightdata.com/cp/setting/users
BRIGHTDATA_API_TOKEN=
